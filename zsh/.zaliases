# Configuration shortcuts
alias reload='exec $SHELL'
alias dotconfig="$EDITOR $DOTDIR"

# Global directory navigation aliases
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Enhanced file listing (eza preferred over ls)
alias la='ls -la'
alias ldot='ls -ld .*'
if (( $+commands[eza] )); then
  alias ls="eza -lh --icons --time-style=long-iso --group-directories-first --sort=name --sort=ext"
  alias tree="eza --icons --tree"
fi

# Enhanced file viewing (bat preferred over cat)
if (( $+commands[bat] )); then
  alias cat="bat --style=plain"
elif (( $+commands[batcat] )); then
  alias cat="batcat --style=plain"
fi

# Date/time utilities
alias timestamp="date '+%Y-%m-%d %H:%M:%S'"
alias datestamp="date '+%Y-%m-%d'"
alias epoch="date +%s"

# System utilities
alias df='df -h'
alias du='du -h'
alias free='free -h'

# Network utilities
alias myip="curl -s ifconfig.me"
alias localip="ip route get 1 | awk '{print \$NF;exit}'"

# Process management
alias psg="ps aux | grep"
alias topcpu="ps auxf | sort -nr -k 3 | head -10"
alias topmem="ps auxf | sort -nr -k 4 | head -10"
